---
interface Props {
  class?: string;
  strokeWidth?: string;
}

const { class: className = "w-4 h-4", strokeWidth = "2" } = Astro.props;
---

<svg
  class={className}
  fill="none"
  stroke="currentColor"
  viewBox="0 0 24 24"
  aria-hidden="true"
>
  <path
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width={strokeWidth}
    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
  ></path>
</svg>
