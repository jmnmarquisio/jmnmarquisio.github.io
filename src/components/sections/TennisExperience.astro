---
import { tennisExperience } from "../../data/content";
import TimelineItem from "../ui/TimelineItem.astro";
import SectionHeader from "../ui/SectionHeader.astro";
---

<section
  id="tennis-experience"
  class="section-padding bg-app-subtle relative overflow-hidden"
>
  <div class="container-main relative">
    <SectionHeader
      label="Tennis Experience"
      title="My Tennis Experience"
      id="tennis-experience"
      showAnchor={false}
    />

    <div class="mt-12">
      {
        tennisExperience.map((exp, i) => (
          <TimelineItem
            experience={exp}
            index={i}
            isLast={i === tennisExperience.length - 1}
          />
        ))
      }
    </div>
  </div>
</section>
