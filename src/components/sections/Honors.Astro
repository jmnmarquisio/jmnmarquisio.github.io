---
import { honors } from "../../data/content";
import SectionHeader from "../ui/SectionHeader.astro";
import Star from "../icons/Star.astro";
---

<section id="honors" class="section-padding">
    <div class="container-main">
        <SectionHeader
            label="Recognition"
            title="Honors & Awards"
            id="honors"
            showAnchor={false}
        />

        <div class="mt-12 space-y-7">
            {
                honors.map((item) => (
                    <div class="border-t border-border pt-6 flex items-start justify-between gap-6">
                        <div>
                            <h4 class="text-body text-primary font-medium">
                                {item.title}
                            </h4>

                            {item.url ? (
                                <a
                                    href={item.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="link-animated text-body-sm text-secondary mt-1 inline-block"
                                >
                                    {item.issuer}
                                </a>
                            ) : (
                                <p class="text-body-sm text-secondary mt-1">
                                    {item.issuer}
                                </p>
                            )}

                            {item.description && (
                                <p class="text-xs text-muted mt-2 max-w-xl">
                                    {item.description}
                                </p>
                            )}
                        </div>

                        <p class="text-xs text-muted whitespace-nowrap pt-1">
                            {item.period}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
