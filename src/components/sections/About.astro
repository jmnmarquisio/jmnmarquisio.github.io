---
import { about } from "../../data/content";
---

<section id="about" class="section-padding">
  <div class="container-main">
    <p class="text-label mb-4 will-animate animate-fade-in-up">
      {about.label}
    </p>

    <div class="about-copy">
      <h2
        class="text-heading text-primary will-animate animate-fade-in-up delay-100"
      >
        {about.title}
      </h2>

      <p
        class="text-body text-secondary mt-6 will-animate animate-fade-in-up delay-200"
      >
        {about.intro}
      </p>

      <div class="about-points mt-6">
        {
          about.points.map((point, i) => (
            <p
              class="text-body text-secondary will-animate animate-fade-in-up"
              style={`animation-delay: ${300 + i * 100}ms`}
            >
              {point}
            </p>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .about-copy {
    max-width: 860px;
  }

  .about-copy h2 {
    max-width: 720px;
  }

  .about-points {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (max-width: 980px) {
    .about-copy,
    .about-copy h2 {
      max-width: 100%;
    }
  }
</style>
