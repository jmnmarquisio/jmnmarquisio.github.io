---
import { about } from "../../data/content";
---

<section id="about" class="section-padding">
  <div class="container-main">
    <p class="text-label mb-4 will-animate animate-fade-in-up">
      {about.label}
    </p>

    <div class="about-copy">
      <h2
        class="text-heading text-primary will-animate animate-fade-in-up delay-100"
      >
        {about.title}
      </h2>

      <p
        class="text-body text-secondary mt-6 will-animate animate-fade-in-up delay-200"
      >
        {about.intro}
      </p>

      <div class="about-points mt-6">
        {
          about.points.map((point, i) => (
            <p
              class="text-body text-secondary will-animate animate-fade-in-up"
              style={`animation-delay: ${300 + i * 100}ms`}
            >
              {point}
            </p>
          ))
        }
      </div>

      <div class="section-divider mt-16 mb-30 will-animate animate-fade-in-up">
      </div>

      <h3
        class="text-subheading text-primary mb-4 will-animate animate-fade-in-up"
        style="animation-delay: 700ms"
      >
        Now, relocating to Zurich
      </h3>

      <div class="about-points">
        <p
          class="text-body text-secondary will-animate animate-fade-in-up"
          style="animation-delay: 800ms"
        >
          I'm relocating to the Zurich area in August/September 2026 and am
          currently seeking entry-level, internship, or graduate opportunities
          in banking, finance, and business or product-related roles.
        </p>

        <p
          class="text-body text-secondary will-animate animate-fade-in-up"
          style="animation-delay: 900ms"
        >
          I spent two consecutive summers working in Switzerland, and those
          experiences strengthened my connection to the country. I was impressed
          not only by its professionalism and quality standards, but also by its
          culture, its people, and its extraordinary nature.
        </p>

        <p
          class="text-body text-secondary will-animate animate-fade-in-up"
          style="animation-delay: 900ms"
        >
          I'm especially drawn to Zurich for its international outlook, strong
          business ecosystem, and understated ambition, a city whose focus and
          calm intensity bring out the best in people.
        </p>
        <p
          class="text-body text-secondary will-animate animate-fade-in-up"
          style="animation-delay: 900ms"
        >
          I'm ready. Let's connect.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .about-copy {
    max-width: 860px;
  }

  .about-copy h2 {
    max-width: 720px;
  }

  .about-points {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (max-width: 980px) {
    .about-copy,
    .about-copy h2 {
      max-width: 100%;
    }
  }
</style>
