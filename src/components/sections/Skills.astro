---
import {
  skillCategories,
  education,
  languages,
  certifications,
  interests,
  geography,
  volunteer,
  honors,
} from "../../data/content";
import SkillBadge from "../ui/SkillBadge.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import Education from "../icons/Education.astro";
import Globe from "../icons/Globe.astro";
import Star from "../icons/Star.astro";
import VolunteerIcon from "../icons/Volunteer.astro";
import HonorsIcon from "../icons/Honors.astro";
import LanguageIcon from "../icons/Language.astro";
---

<section id="skills" class="section-padding">
  <div class="container-main">
    <SectionHeader
      label="Expertise"
      title="Skills & Background"
      id="skills"
      showAnchor={false}
    />

    <div class="mt-12 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        skillCategories.map((category, categoryIndex) => (
          <div
            class="will-animate animate-fade-in-up"
            style={`animation-delay: ${150 + categoryIndex * 75}ms`}
          >
            <h3 class="text-label mb-5 pb-2 border-b border-border">
              {category.name}
            </h3>
            <div class="flex flex-wrap gap-2.5">
              {category.skills.map((skill, skillIndex) => (
                <SkillBadge
                  skill={skill}
                  accent={category.accent || "neutral"}
                  delay={150 + categoryIndex * 75 + skillIndex * 30}
                />
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-20">
      <div class="space-y-20 w-full">
        <!-- Education -->
        <div class="will-animate animate-fade-in-up delay-300">
          <h3 class="text-subheading mb-7 flex items-center gap-3">
            <span class="text-accent">
              <Education class="size-6" />
            </span>
            Education
          </h3>

          <div class="space-y-10">
            <div>
              <p class="text-label mb-5 pb-2 border-b border-border">
                Academic
              </p>

              <div class="space-y-7">
                {
                  education.map((item) => (
                    <div class="flex items-start justify-between gap-6">
                      <div>
                        <h4 class="text-body text-primary font-medium">
                          {item.degree}
                        </h4>

                        {item.url ? (
                          <a
                            href={item.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="link-animated text-body-sm text-secondary mt-1 inline-block"
                          >
                            {item.institution}
                          </a>
                        ) : (
                          <p class="text-body-sm text-secondary mt-1">
                            {item.institution}
                          </p>
                        )}
                      </div>

                      <p class="text-xs text-muted whitespace-nowrap pt-1">
                        {item.graduated}
                      </p>
                    </div>
                  ))
                }
              </div>
            </div>

            {
              certifications.length > 0 && (
                <div>
                  <p class="text-label mb-5 pb-2 border-b border-border">
                    Certifications
                  </p>

                  <div class="space-y-5">
                    {certifications.map((cert) => (
                      <div class="flex items-start justify-between gap-6">
                        <div>
                          <h4 class="text-body text-primary font-medium">
                            {cert.name}
                          </h4>
                          <p class="text-xs text-muted mt-0.5">{cert.status}</p>
                        </div>

                        {cert.url && (
                          <a
                            href={cert.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="link-animated text-body-sm text-secondary whitespace-nowrap"
                          >
                            Certificate
                          </a>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              )
            }
          </div>
        </div>

        <!-- Geography -->
        <div class="will-animate animate-fade-in-up delay-600">
          <h3 class="text-subheading mb-7 flex items-center gap-3">
            <span class="text-accent">
              <Globe class="size-6" />
            </span>
            Geography
          </h3>
          <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
            <div>
              <p class="text-label mb-5 pb-2 border-b border-border">Lived</p>
              <div class="flex flex-wrap gap-2.5 mt-3">
                {
                  geography.lived.map((item) => (
                    <span class="inline-flex items-center px-3 py-1.5 rounded-[10px] bg-app-muted text-body-sm text-secondary transition-colors duration-200 hover:text-primary cursor-default">
                      {item}
                    </span>
                  ))
                }
              </div>
            </div>

            <div>
              <p class="text-label mb-5 pb-2 border-b border-border">
                Lived for 2+ months
              </p>
              <div class="flex flex-wrap gap-2.5 mt-3">
                {
                  geography.livedExtended.map((item) => (
                    <span class="inline-flex items-center px-3 py-1.5 rounded-[10px] bg-app-muted text-body-sm text-secondary transition-colors duration-200 hover:text-primary cursor-default">
                      {item}
                    </span>
                  ))
                }
              </div>
            </div>

            <div>
              <p class="text-label mb-5 pb-2 border-b border-border">Worked</p>
              <div class="flex flex-wrap gap-2.5 mt-3">
                {
                  geography.worked.map((item) => (
                    <span class="inline-flex items-center px-3 py-1.5 rounded-[10px] bg-app-muted text-body-sm text-secondary transition-colors duration-200 hover:text-primary cursor-default">
                      {item}
                    </span>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Languages -->
        <div class="will-animate animate-fade-in-up delay-400">
          <h3 class="text-subheading mb-7 flex items-center gap-3">
            <span class="text-accent">
              <LanguageIcon class="size-6" />
            </span>
            Languages
          </h3>

          <div class="grid gap-10 sm:grid-cols-2">
            <div>
              <p class="text-label mb-5 pb-2 border-b border-border">
                Native / Professional Proficiency
              </p>
              <div class="space-y-5">
                {
                  languages
                    .filter(
                      (lang) =>
                        lang.level === "Native" ||
                        lang.level === "Professional Proficiency",
                    )
                    .map((lang) => (
                      <div>
                        <p class="text-body text-primary font-medium">
                          {lang.name}
                        </p>
                        <p class="text-body-sm text-secondary mt-1">
                          {lang.level}
                        </p>
                      </div>
                    ))
                }
              </div>
            </div>

            <div>
              <p class="text-label mb-5 pb-2 border-b border-border">
                Learning
              </p>
              <div class="space-y-5">
                {
                  languages
                    .filter(
                      (lang) =>
                        lang.level !== "Native" &&
                        lang.level !== "Professional Proficiency",
                    )
                    .map((lang) => (
                      <div>
                        <p class="text-body text-primary font-medium">
                          {lang.name}
                        </p>
                        <p class="text-body-sm text-secondary mt-1">
                          {lang.level}
                        </p>
                      </div>
                    ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Interests -->
        <div class="will-animate animate-fade-in-up delay-500">
          <h3 class="text-subheading mb-7 flex items-center gap-3">
            <span class="text-accent">
              <Star class="size-6" />
            </span>
            Interests
          </h3>

          <div class="grid gap-10 sm:grid-cols-2">
            <div>
              <p class="text-label mb-5 pb-2 border-b border-border">
                Learning
              </p>
              <div class="flex flex-wrap gap-2.5 mt-3">
                {
                  interests.learning.map((item) => (
                    <span class="inline-flex items-center px-3 py-1.5 rounded-[10px] bg-app-muted text-body-sm text-secondary transition-colors duration-200 hover:text-primary cursor-default">
                      {item}
                    </span>
                  ))
                }
              </div>
            </div>

            <div>
              <p class="text-label mb-5 pb-2 border-b border-border">
                Personal
              </p>
              <div class="flex flex-wrap gap-2.5 mt-3">
                {
                  interests.personal.map((item) => (
                    <span class="inline-flex items-center px-3 py-1.5 rounded-[10px] bg-app-muted text-body-sm text-secondary transition-colors duration-200 hover:text-primary cursor-default">
                      {item}
                    </span>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Volunteer -->
        <div class="will-animate animate-fade-in-up delay-350">
          <h3 class="text-subheading mb-7 flex items-center gap-3">
            <span class="text-accent">
              <VolunteerIcon class="size-6" />
            </span>
            Volunteering
          </h3>

          <div>
            <p class="text-label mb-5 pb-2 border-b border-border">
              Community & Service
            </p>

            <div class="space-y-7">
              {
                (volunteer ?? []).map((item) => (
                  <div class="flex items-start justify-between gap-6">
                    <div>
                      <h4 class="text-body text-primary font-medium">
                        {item.role}
                      </h4>

                      {item.url ? (
                        <a
                          href={item.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="link-animated text-body-sm text-secondary mt-1 inline-block"
                        >
                          {item.organization}
                        </a>
                      ) : (
                        <p class="text-body-sm text-secondary mt-1">
                          {item.organization}
                        </p>
                      )}

                      {item.description && (
                        <p class="text-xs text-muted mt-2 max-w-xl">
                          {item.description}
                        </p>
                      )}
                    </div>

                    <p class="text-xs text-muted whitespace-nowrap pt-1">
                      {item.period}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Honors & Awards -->
        <div class="will-animate animate-fade-in-up delay-375">
          <h3 class="text-subheading mb-7 flex items-center gap-3">
            <span class="text-accent">
              <HonorsIcon class="size-6" />
            </span>
            Honors & Awards
          </h3>

          <div>
            <p class="text-label mb-5 pb-2 border-b border-border">
              Recognition
            </p>

            <div class="space-y-7">
              {
                (honors ?? []).map((item) => (
                  <div class="flex items-start justify-between gap-6">
                    <div>
                      <h4 class="text-body text-primary font-medium">
                        {item.title}
                      </h4>

                      {item.url ? (
                        <a
                          href={item.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="link-animated text-body-sm text-secondary mt-1 inline-block"
                        >
                          {item.issuer}
                        </a>
                      ) : (
                        <p class="text-body-sm text-secondary mt-1">
                          {item.issuer}
                        </p>
                      )}

                      {item.description && (
                        <p class="text-xs text-muted mt-2 max-w-xl">
                          {item.description}
                        </p>
                      )}
                    </div>

                    <p class="text-xs text-muted whitespace-nowrap pt-1">
                      {item.period}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
